{
  "name": "root",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@8.10.0",
  "author": {
    "name": "Fery Wardiyanto",
    "email": "ferywardiyanto@gmail.com"
  },
  "license": "MIT",
  "scripts": {
    "build": "pnpm run -r build",
    "emulate": "firebase emulators:start --export-on-exit --import .firebase/exports",
    "firebase": "firebase",
    "lint": "pnpm run -r lint",
    "local-config": "firebase functions:config:get > apps/functions/.runtimeconfig.json",
    "prepare": "simple-git-hooks",
    "publish:packages": "pnpm -r publish --ignore-scripts --no-git-checks",
    "start": "dotenv -e .env run-p emulate watch serve",
    "serve": "pnpm -C apps/website dev",
    "test": "firebase emulators:exec \"vitest run\"",
    "watch": "pnpm run --parallel watch"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^2.27.3",
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.25",
    "@types/glob": "^8.1.0",
    "@types/node": "^20.19.43",
    "@types/supertest": "^6.0.3",
    "@vue/compiler-sfc": "^3.5.39",
    "@vue/server-renderer": "^3.5.39",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^8.57.1",
    "firebase-tools": "^13.35.1",
    "happy-dom": "^14.12.3",
    "lint-staged": "^17.0.8",
    "npm-run-all": "^4.1.5",
    "simple-git-hooks": "^2.13.1",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite": "^5.4.21",
    "vitest": "^1.6.1",
    "vue-tsc": "^2.2.12"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ],
    "rules": {
      "body-max-line-length": [
        2,
        "always",
        100
      ],
      "type-enum": [
        2,
        "always",
        [
          "build",
          "chore",
          "ci",
          "docs",
          "feat",
          "fix",
          "perf",
          "refactor",
          "revert",
          "style",
          "test"
        ]
      ]
    }
  },
  "simple-git-hooks": {
    "commit-msg": "pnpm exec commitlint --edit $1",
    "pre-commit": "pnpm exec lint-staged --allow-empty"
  },
  "lint-staged": {
    "**/*.{js,json,ts,tsx,vue}": [
      "eslint --fix"
    ]
  }
}
